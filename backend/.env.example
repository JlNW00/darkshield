# DarkShield Environment Configuration
# Copy to .env and fill in your values

# Amazon Nova Act SDK - Browser automation
NOVA_ACT_API_KEY=your_nova_act_api_key_here

# AWS Credentials - For Bedrock (Nova 2 Lite classifier)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# Bedrock model ID (default: amazon.nova-lite-v1:0)
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# App server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS - comma-separated allowed origins
CORS_ORIGIN=http://localhost:5173

# Storage - directory for screenshots, audit JSON, and reports
DATA_DIR=data

# Concurrency
MAX_CONCURRENT_AUDITS=3

# Timeouts (seconds)
SCENARIO_TIMEOUT=120
AUDIT_TIMEOUT=600
